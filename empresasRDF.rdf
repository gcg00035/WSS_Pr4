    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/s">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
