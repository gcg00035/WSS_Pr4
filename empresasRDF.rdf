        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Si un accionista es propietario de una empresa, entonces la empresa es propiedad de ese accionista.</rdfs:comment>
        <rdfs:label>Regla 3</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Accionista"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/a"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#es_propietario_de"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/a"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/e"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Es_propiedad_de"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/e"/>
                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/a"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Si un accionista es propietario de una empresa y esa empresa tiene una filial, entonces el accionista también es propietario de la filial.</rdfs:comment>
        <rdfs:label>Regla 5</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Accionista"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/a"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#es_propietario_de"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/a"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/e"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#tiene_filial"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/e"/>
                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/f"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#es_propietario_de"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/a"/>
                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/f"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Si un trabajador está asignado a un departamento, trabaja en esa organización.</rdfs:comment>
        <rdfs:label>Regla 6</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Trabajador"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/t"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                <swrl:classPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Departamento"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/d"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Empresa"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/e"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                        <rdf:first>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#asignado_a"/>
                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/t"/>
                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/d"/>
                                            </rdf:Description>
                                        </rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                <rdf:first>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#compuesta_por"/>
                                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/e"/>
                                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/d"/>
                                                    </rdf:Description>
                                                </rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#trabaja_en"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/t"/>
                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/e"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Un directivo que dirige una empresa también trabaja en ella.</rdfs:comment>
        <rdfs:label>Regla 1</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Directivo"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/d"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#dirige"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/d"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/e"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#trabaja_en"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/d"/>
                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/e"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Si una empresa tiene una sede y tiene una filial, entonces la filial funciona en esa sede.</rdfs:comment>
        <rdfs:label>Regla 7</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#Empresa"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/e"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3#tiene"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/e"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/admin/ontologies/2026/2/untitled-ontology-3/s"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
